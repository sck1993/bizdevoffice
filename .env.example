# Set this to the OpenClaw websocket endpoint once it is known.
# Examples:
# OPENCLAW_URL=ws://openclaw:3000
# OPENCLAW_URL=ws://host.docker.internal:3000
OPENCLAW_URL=

# Optional gateway auth token if your OpenClaw Gateway requires token-based connect.
OPENCLAW_GATEWAY_TOKEN=

# Base directory used when creating OpenClaw agent workspaces.
OPENCLAW_WORKSPACE_ROOT=~/.openclaw/workspaces

